<main x-data="wheelComponent()" x-init="await loadWheel()" class="glass-effect rounded-3xl p-12 shadow-2xl">
    <!-- Header Section -->
    <div class="flex justify-between items-center mb-12">
        <div>
            <h1 class="text-5xl font-bold bg-gradient-to-r from-blue-600 via-purple-600 to-indigo-600 bg-clip-text text-transparent mb-2 py-2">
                Wheel <span x-text="wheel.name" class="text-emerald-600"></span>
            </h1>
        </div>

        <a href="/home">
            <button type="button"
                    class="group relative px-6 py-3 bg-gradient-to-r from-blue-500 to-indigo-600 rounded-2xl shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300 text-white font-semibold cursor-pointer">
                <span class="relative z-10 flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M8 5a2 2 0 012-2h4a2 2 0 012 2v2H8V5z"></path>
                    </svg>
                    Home
                </span>
            </button>
        </a>
    </div>

    <!-- Wheel Management Section -->
    <div class="mb-12">
        <div class="flex flex-col sm:flex-row gap-4 items-center">
            <div x-data="updateWheelForm()">
                <button @click="open = true"
                        class="group relative px-6 py-3 bg-gradient-to-r from-amber-500 to-orange-600 rounded-2xl shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300 text-white font-semibold cursor-pointer">
                    <span class="relative z-10 flex items-center gap-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                        </svg>
                        Update Wheel
                    </span>
                </button>

                <template x-teleport="body">
                    <div x-show="open" x-transition.opacity @click.self="open = false" style="display: none;"
                         class="fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center z-50 p-4">
                        <div x-show="open" x-transition @keydown.escape.window="open = false"
                             class="glass-effect rounded-3xl shadow-2xl max-w-md w-full p-8 relative">
                            <form @submit.prevent="await update(); await loadWheel()">
                                <div class="flex justify-between items-center border-b border-gray-200 pb-6 mb-6">
                                    <h2 class="text-2xl font-bold text-gray-800">Update Wheel</h2>
                                    <button @click="open = false" type="button"
                                            class="text-gray-400 hover:text-gray-600 transition-colors p-2 hover:bg-gray-100 rounded-full cursor-pointer">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                  d="M6 18L18 6M6 6l12 12"></path>
                                        </svg>
                                    </button>
                                </div>

                                <div class="space-y-6">
                                    <div class="space-y-2">
                                        <label for="create-wheel-name" class="text-sm font-semibold text-gray-700">Wheel
                                            Name</label>
                                        <input x-model="name" type="text" id="create-wheel-name"
                                               placeholder="Enter wheel name"
                                               class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-amber-500 focus:border-transparent transition-all duration-200 bg-white/50">
                                    </div>

                                    <p x-show="error" x-text="error"
                                       class="text-red-500 text-sm bg-red-50 p-3 rounded-lg"></p>
                                </div>

                                <div class="mt-8 flex gap-4">
                                    <button @click="open = false" type="button"
                                            class="flex-1 px-6 py-3 bg-gray-100 text-gray-700 rounded-xl hover:bg-gray-200 transition-colors duration-200 font-medium cursor-pointer">
                                        Cancel
                                    </button>
                                    <button type="submit"
                                            class="flex-1 px-6 py-3 bg-gradient-to-r from-amber-500 to-orange-600 text-white rounded-xl hover:shadow-lg transform hover:-translate-y-0.5 transition-all duration-200 font-semibold cursor-pointer">
                                        Update Wheel
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </template>
            </div>

            <div class="text-gray-500 font-medium">or</div>

            <button type="button"
                    class="group relative px-6 py-3 bg-gradient-to-r from-red-500 to-pink-600 rounded-2xl shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300 text-white font-semibold cursor-pointer"
                    x-data="deleteWheelForm()" @click="await deleteWheel()">
                <span class="relative z-10 flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                    </svg>
                    Delete Wheel
                </span>
            </button>
        </div>
    </div>

    <!-- Add Item Section -->
    <div class="mb-12">
        <div x-data="addItemForm()">
            <button @click="open = true"
                    class="group relative px-8 py-4 bg-gradient-to-r from-emerald-500 to-teal-600 rounded-2xl shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300 text-white font-semibold text-lg cursor-pointer">
                <span class="relative z-10 flex items-center gap-3">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                    </svg>
                    Add Item
                </span>
            </button>

            <template x-teleport="body">
                <div x-show="open" x-transition.opacity @click.self="open = false" style="display: none;"
                     class="fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center z-50 p-4">
                    <div x-show="open" x-transition @keydown.escape.window="open = false"
                         class="glass-effect rounded-3xl shadow-2xl max-w-lg w-full p-8 relative">
                        <form @submit.prevent="await create(); await loadItems()">
                            <div class="flex justify-between items-center border-b border-gray-200 pb-6 mb-6">
                                <h2 class="text-2xl font-bold text-gray-800">Add Item</h2>
                                <button @click="open = false" type="button"
                                        class="text-gray-400 hover:text-gray-600 transition-colors p-2 hover:bg-gray-100 rounded-full cursor-pointer">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M6 18L18 6M6 6l12 12"></path>
                                    </svg>
                                </button>
                            </div>

                            <div class="space-y-6">
                                <div class="space-y-2">
                                    <label for="add-item-name" class="text-sm font-semibold text-gray-700 block">Item
                                        Name</label>
                                    <input x-model="name" type="text" id="add-item-name"
                                           placeholder="Enter item name"
                                           class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition-all duration-200 bg-white/50">
                                </div>

                                <div class="space-y-2">
                                    <label for="add-item-path" class="text-sm font-semibold text-gray-700 block">Item
                                        Image</label>
                                    <input x-ref="image" type="file" id="add-item-path" accept="image/*"
                                           placeholder="Select item image"
                                           class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition-all duration-200 bg-white/50">
                                </div>

                                <p x-show="error" x-text="error"
                                   class="text-red-500 text-sm bg-red-50 p-3 rounded-lg"></p>
                            </div>

                            <div class="mt-8 flex gap-4">
                                <button @click="open = false" type="button"
                                        class="flex-1 px-6 py-3 bg-gray-100 text-gray-700 rounded-xl hover:bg-gray-200 transition-colors duration-200 font-medium cursor-pointer">
                                    Cancel
                                </button>
                                <button type="submit"
                                        class="flex-1 px-6 py-3 bg-gradient-to-r from-emerald-500 to-teal-600 text-white rounded-xl hover:shadow-lg transform hover:-translate-y-0.5 transition-all duration-200 font-semibold cursor-pointer">
                                    Add Item
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </template>
        </div>
    </div>

    <!-- Items Section -->
    <div x-init="await loadItems()">
        <div class="flex items-center gap-4 mb-8">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-gradient-to-br from-blue-500 to-purple-600 rounded-xl flex items-center justify-center">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                    </svg>
                </div>
                <h2 class="text-3xl font-bold text-gray-800">Items</h2>
            </div>
            <div class="flex-1 h-px bg-gradient-to-r from-gray-200 to-transparent"></div>
        </div>

        <div class="space-y-4">
            <template x-for="(item, index) in items" :key="item.id">
                <div class="group bg-white/50 backdrop-blur-sm rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 border border-white/20 hover:border-white/40"
                     @dragover.prevent @drop="drop(index)">
                    <div class="flex items-center gap-4">
                        <!-- Drag Handle -->
                        <button type="button" draggable="true" @dragstart="dragStart(index)"
                                class="w-10 h-10 bg-gray-200 hover:bg-gray-300 rounded-xl flex items-center justify-center cursor-move transition-colors duration-200"
                                title="Drag to reorder">
                            <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M4 8h16M4 16h16"></path>
                            </svg>
                        </button>

                        <!-- Item Info -->
                        <div class="flex-1 flex items-center gap-4">
                            <div class="w-16 h-16 rounded-xl overflow-hidden bg-gray-100 flex-shrink-0 border border-gray-200 shadow-sm flex items-center justify-center">
                                <img :src="`/api/wheel/${wheelId}/item/${item.id}/image?v=${imageVersions[item.id] || 0}`"
                                     :alt="item.name"
                                     @load="$event.target.classList.remove('p-4', 'text-gray-400')"
                                     @error="$event.target.src = 'data:image/svg+xml;base64,'; $event.target.classList.add('p-4', 'text-gray-400')"
                                     class="w-full h-full object-cover">
                            </div>
                            <div class="flex flex-col justify-center gap-2">
                                <h3 class="text-xl font-semibold text-gray-800" x-text="item.name"></h3>
                                <div class="flex items-center gap-4">
                                    <!-- Badges -->
                                    <div class="flex items-center gap-2">
                                        <button @click="await toggleUsed(item)"
                                                :class="item.used ? 'bg-emerald-100 text-emerald-700 border-emerald-200' : 'bg-gray-100 text-gray-400 border-gray-200'"
                                                class="px-3 py-1 rounded-full text-xs font-bold border transition-all duration-200 cursor-pointer">
                                            Used
                                        </button>
                                        <button @click="await toggleRejected(item)"
                                                :class="item.rejected ? 'bg-red-100 text-red-700 border-red-200' : 'bg-gray-100 text-gray-400 border-gray-200'"
                                                class="px-3 py-1 rounded-full text-xs font-bold border transition-all duration-200 cursor-pointer">
                                            Rejected
                                        </button>
                                    </div>

                                    <!-- Rating -->
                                    <div class="flex items-center gap-1">
                                        <template x-for="star in 5">
                                            <button @click="await updateRating(item, star)"
                                                    class="focus:outline-none transition-transform duration-200 hover:scale-125 cursor-pointer">
                                                <svg class="w-5 h-5"
                                                     :class="star <= item.rating ? 'text-amber-400 fill-current' : 'text-gray-300'"
                                                     fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                          d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.175 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.382-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path>
                                                </svg>
                                            </button>
                                        </template>
                                        <button x-show="item.rating > 0" @click="await updateRating(item, 0)"
                                                class="ml-1 text-gray-400 hover:text-red-500 transition-colors duration-200 cursor-pointer"
                                                title="Clear rating">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                            </svg>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="flex items-center gap-2">
                            <!-- Update Button -->
                            <div x-data="updateItemForm(item, wheelId)">
                                <button @click="open = true" type="button"
                                        class="group/btn relative px-6 py-3 bg-gradient-to-r from-blue-500 to-indigo-600 rounded-xl shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all duration-200 text-white font-semibold cursor-pointer">
                                    <span class="relative z-10 flex items-center gap-2">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                  d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                        </svg>
                                        Update
                                    </span>
                                </button>

                                <template x-teleport="body">
                                    <div x-show="open" x-transition.opacity @click.self="open = false"
                                         style="display: none;"
                                         class="fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center z-50 p-4">
                                        <div x-show="open" x-transition @keydown.escape.window="open = false"
                                             class="glass-effect rounded-3xl shadow-2xl max-w-lg w-full p-8 relative">
                                            <form @submit.prevent="await update(); refreshImage(item.id); await loadItems()">
                                                <div class="flex justify-between items-center border-b border-gray-200 pb-6 mb-6">
                                                    <h2 class="text-2xl font-bold text-gray-800">Update Item</h2>
                                                    <button @click="open = false" type="button"
                                                            class="text-gray-400 hover:text-gray-600 transition-colors p-2 hover:bg-gray-100 rounded-full cursor-pointer">
                                                        <svg class="w-5 h-5" fill="none" stroke="currentColor"
                                                             viewBox="0 0 24 24">
                                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                                  stroke-width="2"
                                                                  d="M6 18L18 6M6 6l12 12"></path>
                                                        </svg>
                                                    </button>
                                                </div>

                                                <div class="space-y-6">
                                                    <div class="space-y-2">
                                                        <label :for="'update-item-name-' + item.id"
                                                               class="text-sm font-semibold text-gray-700 block">Item
                                                            Name</label>
                                                        <input x-model="name" type="text" :id="'update-item-name-' + item.id"
                                                               placeholder="Enter item name"
                                                               class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 bg-white/50">
                                                    </div>

                                                    <div class="space-y-2">
                                                        <label :for="'update-item-path-' + item.id"
                                                               class="text-sm font-semibold text-gray-700 block">Item
                                                            Image</label>
                                                        <input x-ref="image" type="file" :id="'update-item-path-' + item.id"
                                                               accept="image/*"
                                                               placeholder="Select item image"
                                                               class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 bg-white/50"
                                                               :disabled="removeImage">
                                                    </div>

                                                    <div class="flex items-center gap-2">
                                                        <input x-model="removeImage" type="checkbox" :id="'remove-item-image-' + item.id"
                                                               class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500 transition-all duration-200 cursor-pointer">
                                                        <label :for="'remove-item-image-' + item.id"
                                                               class="text-sm font-semibold text-gray-700 cursor-pointer">Remove
                                                            Image</label>
                                                    </div>

                                                    <p x-show="error" x-text="error"
                                                       class="text-red-500 text-sm bg-red-50 p-3 rounded-lg"></p>
                                                </div>

                                                <div class="mt-8 flex gap-4">
                                                    <button @click="open = false" type="button"
                                                            class="flex-1 px-6 py-3 bg-gray-100 text-gray-700 rounded-xl hover:bg-gray-200 transition-colors duration-200 font-medium cursor-pointer">
                                                        Cancel
                                                    </button>
                                                    <button type="submit"
                                                            class="flex-1 px-6 py-3 bg-gradient-to-r from-blue-500 to-indigo-600 text-white rounded-xl hover:shadow-lg transform hover:-translate-y-0.5 transition-all duration-200 font-semibold cursor-pointer">
                                                        Update Item
                                                    </button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </template>
                            </div>

                            <!-- Delete Button -->
                            <button type="button" @click="await deleteItem(item.id)"
                                    class="group/btn relative px-6 py-3 bg-gradient-to-r from-red-500 to-pink-600 rounded-xl shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all duration-200 text-white font-semibold cursor-pointer">
                                <span class="relative z-10 flex items-center gap-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                    </svg>
                                    Delete
                                </span>
                            </button>
                        </div>
                    </div>
                </div>
            </template>

            <!-- Empty state -->
            <div x-show="items.length === 0" class="text-center py-12">
                <div class="w-20 h-20 bg-gradient-to-br from-gray-300 to-gray-400 rounded-2xl mx-auto mb-6 flex items-center justify-center">
                    <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                    </svg>
                </div>
                <h3 class="text-xl font-semibold text-gray-600 mb-2">No items yet</h3>
                <p class="text-gray-500">Add your first item to start using wheel of fortune</p>
            </div>
        </div>
    </div>
</main>

<script>
    function wheelComponent() {
        return {
            wheelId: "{{ .WheelId }}",

            wheel: {},
            items: [],
            imageVersions: {},

            dragIndex: null,

            async loadWheel() {
                this.wheel = await (await fetch(`/api/wheel/${ this.wheelId }`)).json()
            },

            async loadItems() {
                this.items = await (await fetch(`/api/wheel/${ this.wheelId }/item`)).json()
            },

            refreshImage(itemId) {
                this.imageVersions[itemId] = Date.now()
            },

            dragStart(index) {
                this.dragIndex = index
            },

            async drop(index) {
                if (this.dragIndex === null || this.dragIndex === index) {
                    return
                }

                const moved = this.items.splice(this.dragIndex, 1)[0]
                this.items.splice(index, 0, moved)

                this.dragIndex = null

                await fetch(`/api/wheel/${ this.wheelId }/item/order`, {
                    method: "PUT",
                    headers: {"Content-Type": "application/json"},
                    body: JSON.stringify({
                        ids: this.items.map(a => a.id),
                    }),
                })
            },

            async deleteItem(itemId) {
                const ok = confirm("Are you sure you want to delete this item?")
                if (!ok) {
                    return
                }

                await fetch(`/api/wheel/${ this.wheelId }/item/${ itemId }`, {
                    method: "DELETE",
                    headers: {"Content-Type": "application/json"},
                })

                await this.loadItems()
            },

            async toggleUsed(item) {
                item.used = !item.used
                await fetch(`/api/wheel/${ this.wheelId }/item/${ item.id }/used`, {
                    method: "PUT",
                    headers: {"Content-Type": "application/json"},
                    body: JSON.stringify({used: item.used}),
                })
            },

            async toggleRejected(item) {
                item.rejected = !item.rejected
                await fetch(`/api/wheel/${ this.wheelId }/item/${ item.id }/rejected`, {
                    method: "PUT",
                    headers: {"Content-Type": "application/json"},
                    body: JSON.stringify({rejected: item.rejected}),
                })
            },

            async updateRating(item, rating) {
                item.rating = rating
                await fetch(`/api/wheel/${ this.wheelId }/item/${ item.id }/rating`, {
                    method: "PUT",
                    headers: {"Content-Type": "application/json"},
                    body: JSON.stringify({rating: item.rating}),
                })
            },
        }
    }

    function updateWheelForm() {
        return {
            open: false,
            wheelId: "",
            name: "",
            error: "",

            init() {
                this.$watch("wheel", value => {
                    if (this.error !== "") {
                        return
                    }
                    this.wheelId = value.id
                    this.name = value.name
                })
            },

            async update() {
                this.error = ""

                if (this.name === "") {
                    this.error = "Empty name"
                    return
                }

                try {
                    let res = await fetch(`/api/wheel/${ this.wheelId }`, {
                        method: "PUT",
                        headers: {"Content-Type": "application/json"},
                        body: JSON.stringify({
                            name: this.name,
                        }),
                    })

                    if (!res.ok) {
                        let msg = await res.text()
                        throw new Error(msg || "Update failed")
                    }

                    this.open = false
                } catch (err) {
                    this.error = err.message
                }
            },
        }
    }

    function deleteWheelForm() {
        return {
            wheelId: "",

            init() {
                this.$watch("wheel", value => {
                    this.wheelId = value.id
                })
            },

            async deleteWheel() {
                const ok = confirm("Are you sure you want to delete this wheel?")
                if (!ok) {
                    return
                }

                await fetch(`/api/wheel/${ this.wheelId }`, {
                    method: "DELETE",
                    headers: {"Content-Type": "application/json"},
                })

                window.location.href = "/home"
            },
        }
    }

    function addItemForm() {
        return {
            open: false,
            name: "",
            image: null,
            error: "",

            wheelId: "",

            init() {
                this.$watch("wheel", value => {
                    this.wheelId = value.id
                })
            },

            async create() {
                this.error = ""

                if (this.name === "" && !this.$refs.image.files[0]) {
                    this.error = "Empty name and image"
                    return
                }

                let imageData = ""
                if (this.$refs.image.files[0]) {
                    const reader = new FileReader()
                    const promise = new Promise((resolve, reject) => {
                        reader.onload = () => resolve(reader.result.split(",")[1])
                        reader.onerror = reject
                    })
                    reader.readAsDataURL(this.$refs.image.files[0])
                    imageData = await promise
                }

                try {
                    let res = await fetch(`/api/wheel/${ this.wheelId }/item`, {
                        method: "POST",
                        headers: {"Content-Type": "application/json"},
                        body: JSON.stringify({
                            name: this.name,
                            image: imageData,
                        }),
                    })

                    if (!res.ok) {
                        let msg = await res.text()
                        throw new Error(msg || "Creation failed")
                    }

                    this.open = false
                    this.name = ""
                    this.$refs.image.value = ""
                } catch (err) {
                    this.error = err.message
                }
            },
        }
    }

    function updateItemForm(item, wheelId) {
        return {
            open: false,
            itemId: item.id,
            name: item.name,
            removeImage: false,
            error: "",

            wheelId: wheelId,

            async update() {
                this.error = ""

                if (this.name === "" && !this.$refs.image.files[0] && !this.removeImage) {
                    this.error = "Empty name and image"
                    return
                }

                try {
                    if (this.name !== item.name) {
                        let res = await fetch(`/api/wheel/${ this.wheelId }/item/${ this.itemId }`, {
                            method: "PUT",
                            headers: {"Content-Type": "application/json"},
                            body: JSON.stringify({
                                name: this.name,
                            }),
                        })

                        if (!res.ok) {
                            let msg = await res.text()
                            throw new Error(msg || "Update failed")
                        }
                    }

                    if (this.$refs.image.files[0] || this.removeImage) {
                        let imageData = ""
                        if (!this.removeImage && this.$refs.image.files[0]) {
                            const reader = new FileReader()
                            const promise = new Promise((resolve, reject) => {
                                reader.onload = () => resolve(reader.result.split(",")[1])
                                reader.onerror = reject
                            })
                            reader.readAsDataURL(this.$refs.image.files[0])
                            imageData = await promise
                        }

                        let res = await fetch(`/api/wheel/${ this.wheelId }/item/${ this.itemId }/image`, {
                            method: "PUT",
                            headers: {"Content-Type": "application/json"},
                            body: JSON.stringify({
                                image: imageData,
                                remove: this.removeImage,
                            }),
                        })

                        if (!res.ok) {
                            let msg = await res.text()
                            throw new Error(msg || "Image update failed")
                        }
                    }

                    this.open = false
                    this.removeImage = false
                } catch (err) {
                    this.error = err.message
                }
            },
        }
    }

</script>
